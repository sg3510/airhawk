menu "SEN66 Configuration"

    config SEN66_I2C_SDA_PIN
        int "I2C SDA Pin"
        default 6
        help
            GPIO number for I2C master data

    config SEN66_I2C_SCL_PIN
        int "I2C SCL Pin"
        default 7
        help
            GPIO number for I2C master clock

    config SEN66_POLL_INTERVAL_MS
        int "Sensor polling interval (ms)"
        default 5000
        help
            How often to read measurements from the SEN66 sensor

endmenu
